{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/match/:id", "destination": "/match.html?id=:id" },
    { "source": "/pronostic/:id", "destination": "/pronostic.html?id=:id" }
  ],
  "functions": {
    "api/whop-webhook.js": { "maxDuration": 10 },
    "api/resolve-match.js": { "maxDuration": 30 }
  }
}
